// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// PORTAL USERS — internal staff only (superadmin | lead | developer)
// Profile stored directly on the record — no membership join needed.
// ─────────────────────────────────────────────────────────────────────────────

model PortalUser {
  id                        String                  @id @default(uuid())
  email                     String                  @unique
  password                  String

  // Profile
  first_name                String?
  last_name                 String?
  phone                     String?

  // Role — "superadmin" | "lead" | "developer"
  role                      String[]                @default(["lead"])
  status                    String                  @default("active")
  is_deleted                Boolean                 @default(false)

  // Security
  login_attempts            Int                     @default(0)
  lock_until                DateTime?
  resetPasswordToken        String?
  resetPasswordExpires      DateTime?
  lastVerifiedAt            DateTime?
  verificationCode          Int?
  verificationCodeExpiresAt DateTime?
  isVerified                Boolean                 @default(false)

  // Audit
  createdBy                 String?
  creator                   PortalUser?             @relation("PortalUserToCreator", fields: [createdBy], references: [id])
  createdUsers              PortalUser[]            @relation("PortalUserToCreator")
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  // Relations
  createdCompanies          Company[]               @relation("CompanyCreatedBy")
  refreshTokens             UniversalRefreshToken[] @relation("PortalUserRefreshTokens")

  @@map("portal_users")
}

// ─────────────────────────────────────────────────────────────────────────────
// GLOBAL USERS — universal identity, intentionally minimal.
// One identity, many products. Profile data lives in each product's own DB.
// Company admin profile is denormalised on the Company record for portal display.
// platform_role: "CompanyAdmin" | "User"
// ─────────────────────────────────────────────────────────────────────────────

model GlobalUser {
  id                      String                  @id @default(uuid())
  global_user_id          String                  @unique @default(uuid())
  email                   String                  @unique
  password_hash           String
  username                String?                 @unique

  // Access
  platform_role           String                  @default("User")
  global_company_id       String?
  status                  String                  @default("Active")

  // Verification
  verification_code       String?
  verification_token      String?
  verification_expires_at DateTime?

  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  refreshTokens           UniversalRefreshToken[] @relation("GlobalUserRefreshTokens")

  @@map("global_users")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPANY
// Admin identity is stored via admin_global_user_id (link to GlobalUser).
// Admin display fields (email, first_name, last_name) are denormalised here
// so the superadmin portal never needs to query product DBs.
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id                   String      @id @default(uuid())
  name                 String
  logoUrl              String?
  productIds           String[]    @default([])
  domain               String?
  db_uri               String?
  dbName               String?
  admin_global_user_id String?
  admin_email          String?
  admin_first_name     String?
  admin_last_name      String?
  createdBy            String?
  creator              PortalUser? @relation("CompanyCreatedBy", fields: [createdBy], references: [id])
  status               String      @default("inactive")
  enabled_features     Json        @default("{\"billing\": true, \"reports\": true, \"map_monitoring\": true, \"messaging\": true, \"teams\": true}")
  capacity_limits      Json        @default("{\"max_users\": 0, \"max_admins\": 0, \"max_dispatchers\": 0, \"max_drivers\": 0, \"max_managers\": 0, \"max_jobs_per_day\": 0, \"max_trips_per_day\": 0, \"max_clinics\": 0, \"max_routes\": 0, \"max_willcalls\": 0}")
  is_trial             Boolean     @default(false)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// VISA — product-level access grant for a GlobalUser
// ─────────────────────────────────────────────────────────────────────────────

model Visa {
  id           String     @id @default(uuid())
  globalUserId String     @map("global_user_id")
  productId    String     @map("product_id")
  role         String     @default("User")
  status       VisaStatus @default(Active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([globalUserId, productId])
  @@map("visas")
}

enum VisaStatus {
  Active
  Suspended
}

// ─────────────────────────────────────────────────────────────────────────────
// UNIVERSAL REFRESH TOKEN
// Exactly one of portal_user_id or global_user_id is populated per row.
// ─────────────────────────────────────────────────────────────────────────────

model UniversalRefreshToken {
  id             String      @id @default(uuid())
  token          String      @unique

  // Set when the token belongs to a PortalUser (superadmin / lead / developer)
  portal_user_id String?
  portalUser     PortalUser? @relation("PortalUserRefreshTokens", fields: [portal_user_id], references: [id], onDelete: Cascade)

  // Set when the token belongs to a GlobalUser (company admin / product user)
  global_user_id String?
  globalUser     GlobalUser? @relation("GlobalUserRefreshTokens", fields: [global_user_id], references: [global_user_id], onDelete: Cascade)

  expiresAt      DateTime    @map("expires_at")
  revoked        Boolean     @default(false)
  userAgent      String?     @map("user_agent")
  ipAddress      String?     @map("ip_address")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@map("universal_refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCT REGISTRY
// ─────────────────────────────────────────────────────────────────────────────

model ProductRegistry {
  id                  String             @id @default(uuid())
  product_id          String             @unique @default(uuid())
  name                String             @unique
  description         String?
  architecture_type   ArchitectureType   @map("architecture_type")
  db_driver           DbDriver           @map("db_driver")
  db_uri              String             @map("db_uri")
  app_private_key     String             @map("app_private_key")
  app_public_key      String             @map("app_public_key")
  server_api_key      String             @unique @default(dbgenerated("gen_random_uuid()")) @map("server_api_key")
  verification_method VerificationMethod @default(code) @map("verification_method")
  frontend_url        String?            @map("frontend_url")
  ui_schema           Json?              @default("[]") @map("ui_schema")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  @@map("product_registries")
}

enum ArchitectureType {
  SINGLE_DB
  MULTI_TENANT
}

enum DbDriver {
  MONGODB
  MYSQL
  POSTGRESQL
}

enum VerificationMethod {
  code
  link
  none
}

// ─────────────────────────────────────────────────────────────────────────────
// EXCEPTION LOGS — cross-platform system error ingestion gateway
// Written by the universal log ingestion endpoint (POST /api/v1/logs/errors).
// Errors shipped from any registered product land here.
// Super Admins (engineering team) get a single pane of glass across all tenants.
// Company admins NEVER see this table — it is an infrastructure concern only.
// ─────────────────────────────────────────────────────────────────────────────

model ExceptionLog {
  id String @id @default(cuid())

  // ── Identification block (required for gateway admission) ──────────────────
  // Identifies which product/company/user originated the exception.
  product_id String // registered product_id from ProductRegistry
  company_id String // tenant company_id (can be "N/A" for non-tenant errors)
  user_id    String? // global_user_id of the actor who triggered the error

  // ── Request context ────────────────────────────────────────────────────────
  method      String? // HTTP method: GET, POST, PUT, PATCH, DELETE
  path        String? // Request path: /api/v1/users/123
  status_code Int? // HTTP status code, typically 500

  // ── Error details ──────────────────────────────────────────────────────────
  error_name    String // Error class name: TypeError, ReferenceError, etc.
  error_message String // Human-readable error message
  stack_trace   String? @db.Text // Full stack trace — unbounded length

  // ── Runtime metadata ───────────────────────────────────────────────────────
  platform    String? // Caller platform: "express", "nestjs", "php", etc.
  environment String? // "production", "staging", "development"
  ip_address  String? // Client/server IP of the originating request
  user_agent  String? // Browser/client user agent string
  request_body Json? // Sanitised request body snapshot (no passwords/tokens)

  createdAt DateTime @default(now())

  // ── Composite indexes for high-performance dashboard filtering ─────────────
  // Allows fast queries like: all errors for company X, product Y, last 7 days
  @@index([company_id])
  @@index([product_id])
  @@index([createdAt])
  @@index([company_id, product_id])
  @@index([company_id, createdAt])
  @@index([product_id, createdAt])
  @@map("exception_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIVITY LOGS — records routine system actions performed by portal or global users
// ─────────────────────────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  
  // Who performed the action
  actor_id    String?  // portal_user_id or global_user_id
  
  // What happened
  action      String   // e.g., 'POST /api/v1/companies', 'DELETE_USER'
  entity_type String?  // Optional: The controller or entity affected, e.g., 'CompaniesController'
  entity_id   String?  // Optional: The specific record ID affected
  
  // Details and context
  details     Json?    // Sanitised request body or context
  ip_address  String?
  user_agent  String?
  
  createdAt   DateTime @default(now())

  @@index([actor_id])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}
